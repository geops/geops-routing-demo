{
  "name": "geops-routing-demo",
  "description": "Sample component that uses geOps Routing API",
  "main": "build/index.js",
  "version": "1.0.0",
  "homepage": "https://routing-demo.geops.io/",
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@hello-pangea/dnd": "18.0.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@turf/combine": "6.5.0",
    "@turf/nearest-point-on-line": "6.5.0",
    "css-mediaquery": "0.1.2",
    "maplibre-gl": "5.20.0",
    "mobility-toolbox-js": "3.6.11",
    "ol": "10",
    "prop-types": "15.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "9.2.0",
    "react-spatial": "2.0.3",
    "recharts": "3.8.0",
    "redux": "4.2.1",
    "redux-thunk": "2.4.2"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "5.1.4",
    "canvas": "3.2.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-cypress": "2.13.3",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-vitest-globals": "^1.6.1",
    "eslint": "8.44.0",
    "fixpack": "4.0.0",
    "generact": "0.4.0",
    "gh-pages": "5.0.0",
    "husky": "8.0.3",
    "is-ci": "3.0.1",
    "jsdom": "28.1.0",
    "lint-staged": "13.2.3",
    "prettier": "3.8.1",
    "redux-mock-store": "1.5.4",
    "sass": "1.98.0",
    "stylelint": "15.10.1",
    "stylelint-config-recommended-scss": "12.0.0",
    "stylelint-config-standard": "34.0.0",
    "stylelint-scss": "5.0.1",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "scripts": {
    "cp": "generact --root src/Components",
    "deploy:ghpages": "gh-pages -d build",
    "eject": "react-scripts eject",
    "format": "prettier --write 'src/**/*.{js,jsx}' && eslint 'src/**/*.{js,jsx}' --fix && stylelint 'src/**/*.css' 'src/**/*.scss' --fix",
    "lint": "eslint 'src/**/*.{js,jsx}' && stylelint 'src/**/*.{css,scss}'",
    "prepare": "is-ci || husky install",
    "test": "vitest",
    "up": "pnpm upgrade-interactive --latest",
    "dev": "ESLINT_NO_DEV_ERRORS=true vite",
    "build": "vite build",
    "serve": "vite preview"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all",
    "not ie <= 11",
    "not android < 5"
  ],
  "eslintConfig": {
    "env": {
      "node": true,
      "browser": true,
      "es6": true,
      "vitest-globals/env": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "jsx": true,
      "impliedStrict": true
    },
    "extends": [
      "airbnb",
      "airbnb/hooks",
      "prettier",
      "plugin:vitest-globals/recommended"
    ],
    "plugins": [
      "prettier",
      "vitest-globals"
    ],
    "overrides": [
      {
        "files": [
          "vite.config.*"
        ],
        "rules": {
          "import/no-extraneous-dependencies": "off",
          "import/no-unresolved": "off"
        }
      }
    ],
    "rules": {
      "no-undef": "error",
      "import/no-unresolved": "error",
      "arrow-body-style": 0,
      "react/forbid-prop-types": "off",
      "prettier/prettier": "error",
      "react/require-default-props": "off",
      "import/no-extraneous-dependencies": [
        "error",
        {
          "devDependencies": [
            "**/setupTests.js",
            "**/*.test.jsx",
            "**/*.test.js"
          ]
        }
      ]
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    }
  },
  "keywords": [
    "demo",
    "geops",
    "gis",
    "openlayers",
    "routing"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/lang/*.json": [
      "pnpm sort"
    ],
    "(src|__mocks__)/**/*.js": [
      "eslint --fix",
      "prettier --write",
      "pnpm test --bail --related"
    ],
    "package.json": [
      "fixpack --sortToTop name --sortToTop description --sortToTop main --sortToTop version --sortToTop private --sortToTop homepage --sortToTop dependencies --sortToTop peerDependencies --sortToTop devDependencies --sortToTop scripts"
    ],
    "src/**/*.{css,scss}": [
      "stylelint --fix"
    ]
  },
  "prettier": {
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/geops/geops-routing-demo.git"
  },
  "stylelint": {
    "plugins": [
      "stylelint-scss"
    ],
    "extends": [
      "stylelint-config-standard",
      "stylelint-config-recommended-scss"
    ],
    "rules": {
      "selector-pseudo-class-no-unknown": [
        true,
        {
          "ignorePseudoClasses": [
            "export"
          ]
        }
      ],
      "property-no-unknown": [
        true,
        {
          "ignoreProperties": [
            "/^brandprimary/",
            "/gray/"
          ]
        }
      ]
    }
  },
  "packageManager": "pnpm@10.28.2+sha256.afa99b0b4b3d11c1dad2b472f9318ae2c78673829749ded527f89f09071479a7"
}
